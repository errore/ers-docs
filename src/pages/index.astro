  <style>
    html {
      scroll-behavior: smooth;
    }

    .node-demo-container :global(canvas) {
      max-width: 100%;
    }

    .feature-card {
      transform: translateY(30px);
      opacity: 0;
      transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .feature-card.visible {
      transform: translateY(0);
      opacity: 1;
    }
  </style>

  <script>
    function goToDocs() {
    var lang = document.documentElement.lang || 'en';
    var docsUrl = '/' + lang.toLocaleLowerCase() + '/getting-started';
    window.location.href = docsUrl;
  }

    var headerCta = document.getElementById("header-cta");
    var heroPrimaryBtn = document.getElementById("hero-primary-btn");
    var heroSecondaryBtn = document.getElementById("hero-secondary-btn");
    var ctaButton = document.getElementById("cta-button");
    var navFeatures = document.getElementById("nav-features");
    var navDeferred = document.getElementById("nav-deferred");
    var navForward = document.getElementById("nav-forward");
    var scrollIndicator = document.getElementById("scroll-indicator");

    if (headerCta) headerCta.addEventListener("click", goToDocs);
    if (heroPrimaryBtn) heroPrimaryBtn.addEventListener("click", goToDocs);
    if (ctaButton) ctaButton.addEventListener("click", goToDocs);
    
    if (heroSecondaryBtn) {
      heroSecondaryBtn.addEventListener("click", function() {
        var features = document.getElementById("features");
        if (features) features.scrollIntoView({ behavior: "smooth" });
      });
    }
    
    if (navFeatures) {
      navFeatures.addEventListener("click", function() {
        var features = document.getElementById("features");
        if (features) features.scrollIntoView({ behavior: "smooth" });
      });
    }
    
    if (navDeferred) {
      navDeferred.addEventListener("click", function() {
        var sections = document.querySelectorAll('section');
        sections.forEach(function(section) {
          var h2 = section.querySelector('h2');
          if (h2 && (h2.textContent.indexOf('延迟渲染管线') !== -1 || h2.textContent.indexOf('Deferred Rendering Pipeline') !== -1)) {
            section.scrollIntoView({ behavior: "smooth" });
          }
        });
      });
    }
    
    if (navForward) {
      navForward.addEventListener("click", function() {
        var sections = document.querySelectorAll('section');
        sections.forEach(function(section) {
          var h2 = section.querySelector('h2');
          if (h2 && (h2.textContent.indexOf('前向渲染管线') !== -1 || h2.textContent.indexOf('Forward Rendering Pipeline') !== -1)) {
            section.scrollIntoView({ behavior: "smooth" });
          }
        });
      });
    }

    if (scrollIndicator) {
      scrollIndicator.addEventListener("click", function() {
        var features = document.getElementById("features");
        if (features) features.scrollIntoView({ behavior: "smooth" });
      });
    }

    var langSwitcher = document.getElementById("lang-switcher");
    var langDropdown = document.getElementById("lang-dropdown");
    if (langSwitcher && langDropdown) {
      langSwitcher.addEventListener("click", function(e) {
        e.stopPropagation();
        langDropdown.classList.toggle("hidden");
      });
      document.addEventListener("click", function() {
        langDropdown.classList.add("hidden");
      });
    }

    document.querySelectorAll('.faq-toggle').forEach(function(toggle) {
      toggle.addEventListener('click', function() {
        var item = toggle.closest('.faq-item');
        var content = item ? item.querySelector('.faq-content') : null;
        var icon = item ? item.querySelector('.faq-icon') : null;
        
        var isOpen = content && content.classList.contains('open');
        
        document.querySelectorAll('.faq-content').forEach(function(c) {
          c.classList.remove('open');
          c.style.maxHeight = '0';
        });
        document.querySelectorAll('.faq-icon').forEach(function(i) {
          i.style.transform = 'rotate(0deg)';
        });
        
        if (!isOpen && content) {
          content.classList.add('open');
          content.style.maxHeight = content.scrollHeight + 'px';
          if (icon) {
            icon.style.transform = 'rotate(180deg)';
          }
        }
      });
    });

    var observerOptions = {
      threshold: 0.2,
      rootMargin: "0px 0px -50px 0px"
    };

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.feature-card').forEach(function(card) {
      observer.observe(card);
    });
  </script>
</html>
