---
import "../styles/global.css";
import "flag-icons/css/flag-icons.min.css";

const lang = Astro.currentLocale || 'en';
const t = Astro.locals.t;

const languages = [
  { code: 'en', label: 'English', flag: 'gb' },
  { code: 'zh-cn', label: '中文', flag: 'cn' },
];
const otherLangs = languages.filter(l => l.code !== lang.toLocaleLowerCase());
---

<html lang={lang}>
  <head>
    <title>ERS - {t("landing.subtitle")}</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t("landing.description")} />
  </head>
  <body class="bg-[#F4F4EF] text-[#1a1a1a] overflow-x-hidden">
    <header class="fixed top-0 z-50 w-full h-17 px-5 md:px-20 bg-[#F4F4EF] border-b border-[#E0DFD6]">
      <div class="flex justify-between items-center h-full max-w-7xl mx-auto">
        <a href="/" class="flex items-center">
          <svg viewBox="0 0 850 284" class="h-8 w-auto">
            <g>
              <path d="M461.539,74.545l104.592,-0l0,29.849l-104.801,0l-0,178.939l74.686,0l0,-104.394l30.116,0l0,104.394l74.686,0l0,-195.179l-0.01,0c-0.704,-48.739 -40.452,-88.044 -89.419,-88.153l0,-0.001l-0.201,0l-0.009,-0l0,0l-89.639,0l0,74.545Z" style="fill:#1a1a1a;"/>
              <path d="M670.513,283.333l89.429,0c49.506,0 89.639,-40.057 89.639,-89.47l-0,-0.002l0,-89.465l-89.025,0l-0.034,-0l-0.37,-0.001l0,-29.85l89.848,0l0,-74.545l-89.848,0c-49.506,0 -89.639,40.057 -89.639,89.47c-0,0 -0,89.47 -0,89.47l89.429,0l0,29.849l-89.429,0l0,74.545Z" style="fill:#1a1a1a;"/>
              <rect x="0" y="208.789" width="430.95" height="74.545" style="fill:#4646b9;"/>
              <rect x="-0" y="104.394" width="431.423" height="74.545" style="fill:#16a34a;"/>
              <rect x="0.474" y="-0" width="430.95" height="74.545" style="fill:#B94747;"/>
            </g>
          </svg>
        </a>
        
        <nav class="hidden xl:flex items-center gap-3">
          <button id="nav-features" class="px-4 py-2 text-sm font-normal hover:font-medium rounded-full transition-colors text-[#1a1a1a] cursor-pointer">
            {t("landing.featuresTitle")}
          </button>
          <button id="nav-deferred" class="px-4 py-2 text-sm font-normal hover:font-medium rounded-full transition-colors text-[#1a1a1a] cursor-pointer">
            {t("landing.deferredTitle")}
          </button>
          <button id="nav-forward" class="px-4 py-2 text-sm font-normal hover:font-medium rounded-full transition-colors text-[#1a1a1a] cursor-pointer">
            {t("landing.forwardTitle")}
          </button>
        </nav>

        <div class="flex items-center gap-2 md:gap-3">
          <a href="https://discord.gg/yv9zzhPP88" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-2 md:px-3 py-1.5 text-sm text-[#7F7F7F] hover:text-[#1a1a1a] hover:bg-[#1a1a1a]/5 rounded-full transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.32 4.37a19.8 19.8 0 0 0-4.93-1.51 13.78 13.78 0 0 0-.64 1.28 18.27 18.27 0 0 0-5.5 0 12.64 12.64 0 0 0-.64-1.28h-.05A19.74 19.74 0 0 0 3.64 4.4 20.26 20.26 0 0 0 .11 18.09l.02.02a19.9 19.9 0 0 0 6.04 3.03l.04-.02a14.24 14.24 0 0 0 1.23-2.03.08.08 0 0 0-.05-.07 13.1 13.1 0 0 1-1.9-.92.08.08 0 0 1 .02-.1 10.2 10.2 0 0 0 .41-.31h.04a14.2 14.2 0 0 0 12.1 0l.04.01a9.63 9.63 0 0 0 .4.32.08.08 0 0 1-.03.1 12.29 12.29 0 0 1-1.9.91.08.08 0 0 0-.02.1 15.97 15.97 0 0 0 1.27 2.01h.04a19.84 19.84 0 0 0 6.03-3.05v-.03a20.12 20.12 0 0 0-3.57-13.69ZM8.02 15.33c-1.18 0-2.16-1.08-2.16-2.42 0-1.33.96-2.42 2.16-2.42 1.21 0 2.18 1.1 2.16 2.42 0 1.34-.96 2.42-2.16 2.42Zm7.97 0c-1.18 0-2.15-1.08-2.15-2.42 0-1.33.95-2.42 2.15-2.42 1.22 0 2.18 1.1 2.16 2.42 0 1.34-.94 2.42-2.16 2.42Z"/>
            </svg>
            <span class="hidden md:inline">Discord</span>
          </a>
          <a href="https://www.fab.com/listings/b8cd33e0-1007-4aae-87c3-3d8039dc091b" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-2 md:px-3 py-1.5 text-sm text-[#7F7F7F] hover:text-[#1a1a1a] hover:bg-[#1a1a1a]/5 rounded-full transition-colors">
            <svg class="w-auto h-3.5" viewBox="0 0 51 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M49.7196 15.0277C50.0356 14.8193 50.2625 14.5619 50.4008 14.2543C50.539 13.9472 50.608 13.5655 50.608 13.1091C50.608 12.509 50.4243 12.0108 50.0581 11.6143C48.9725 14.8096 46.3271 18.2091 42.5476 21.3181H45.587C47.4729 21.3181 48.7615 20.8919 49.4528 20.0393C49.9365 19.4545 50.1787 18.6613 50.1787 17.6598C50.1787 17.0948 50.0231 16.6537 49.712 16.3364C49.4008 16.0191 48.9788 15.7861 48.4455 15.6375L48.4604 15.489C48.9344 15.4197 49.354 15.266 49.7196 15.028V15.0277Z" fill="currentColor"/>
              <path d="M8.71113 10.7005H2.9736L0.949402 21.3186C1.79934 17.8659 4.57334 14.1091 8.71078 10.7002L8.71113 10.7005Z" fill="currentColor"/>
              <path d="M26.5096 20.3516H20.8812L20.2146 21.3184H13.6676L15.4839 18.7754H7.35771L6.86882 21.3184H0.94938C0.618135 23.0554 0.580714 24.7151 1.19851 26.2152C3.99815 33.016 17.2109 33.9556 30.7101 28.3136C35.3014 26.3947 39.3342 23.9616 42.5476 21.3184H26.8204L26.5093 20.3516H26.5096Z" fill="currentColor"/>
              <path d="M24.6285 14.8198L22.7769 17.5413H25.606L24.7321 14.8198H24.6285Z" fill="currentColor"/>
              <path d="M17.1485 14.4479H8.18722L7.95023 15.6673H16.4226L15.9403 18.1362L21.2513 10.7002H29.4423L32.7527 20.5877L34.656 10.7002H47.0981C48.3125 10.7002 49.2013 10.9159 49.7643 11.3472C49.8731 11.4304 49.9708 11.5198 50.0585 11.6148C50.7632 9.54 50.8107 7.5515 50.0834 5.78461C47.2838 -1.01614 34.0711 -1.95577 20.5718 3.68618C15.9694 5.60962 11.9283 8.05002 8.71112 10.7005H17.8595L17.1485 14.4483V14.4479Z" fill="currentColor"/>
              <path d="M43.4544 13.541H40.0328L39.7663 14.9092H43.1879C43.5434 14.9092 43.805 14.8052 43.9731 14.5968C44.1113 14.4285 44.1806 14.2597 44.1806 14.0914C44.1806 13.7247 43.9384 13.541 43.4547 13.541H43.4544Z" fill="currentColor"/>
              <path d="M42.9356 17.1543H39.3363L39.055 18.6116H42.6394C43.0341 18.6116 43.3157 18.5027 43.4838 18.2846C43.543 18.2052 43.5922 18.1162 43.6317 18.0167C43.6712 17.9179 43.691 17.8285 43.691 17.7492C43.691 17.3526 43.4391 17.1543 42.9356 17.1543Z" fill="currentColor"/>
            </svg>
            <span class="hidden md:inline">{t("landing.fabStore")}</span>
          </a>
          <div class="relative" id="lang-switcher-container">
            <button
              id="lang-switcher"
              class="flex items-center gap-2 px-2 md:px-3 py-1.5 text-sm text-[#7F7F7F] hover:text-[#1a1a1a] hover:bg-[#1a1a1a]/5 rounded-full transition-colors"
              aria-label="Switch language"
            >
              <svg viewBox="0 0 16 16" class="w-4 h-4" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M4 0H6V2H10V4H8.86807C8.57073 5.66996 7.78574 7.17117 6.6656 8.35112C7.46567 8.73941 8.35737 8.96842 9.29948 8.99697L10.2735 6H12.7265L15.9765 16H13.8735L13.2235 14H9.77647L9.12647 16H7.0235L8.66176 10.9592C7.32639 10.8285 6.08165 10.3888 4.99999 9.71246C3.69496 10.5284 2.15255 11 0.5 11H0V9H0.5C1.5161 9 2.47775 8.76685 3.33437 8.35112C2.68381 7.66582 2.14629 6.87215 1.75171 6H4.02179C4.30023 6.43491 4.62904 6.83446 4.99999 7.19044C5.88743 6.33881 6.53369 5.23777 6.82607 4H0V2H4V0ZM12.5735 12L11.5 8.69688L10.4265 12H12.5735Z"></path>
              </svg>
            </button>
            <div id="lang-dropdown" class="hidden absolute right-0 top-full mt-2 py-2 bg-white rounded-xl shadow-lg border border-[#E0DFD6] min-w-[140px] z-50">
              {otherLangs.map(l => (
                <a
                  href={`/${l.code}`}
                  class="flex items-center gap-2 px-4 py-2 text-sm text-[#1a1a1a] hover:bg-[#F4F4EF] transition-colors"
                >
                  <span class={`fi fi-${l.flag}`}></span>
                  <span>{l.label}</span>
                </a>
              ))}
            </div>
          </div>
          <button
            id="header-cta"
            class="px-4 md:px-5 py-2 h-9 text-sm rounded-full bg-[#1a1a1a] text-white hover:bg-[#333333] transition-colors whitespace-nowrap"
          >
            {t("landing.gettingStarted")}
          </button>
        </div>
      </div>
    </header>

    <main class="pt-[68px]">
      <section class="hero relative min-h-[calc(100vh-68px)] flex items-center">
        <div class="container mx-auto px-5 md:px-20 max-w-7xl">
          <div class="flex flex-col-reverse lg:flex-row items-center justify-between gap-10 lg:gap-20">
            <div class="text-left max-w-xl">
              <h1 class="text-[40px] md:text-[48px] font-semibold mb-6 text-[#000000F2] leading-[1.2]" style="font-family: Georgia, 'Times New Roman', serif;">
                {t("landing.title")}
              </h1>
              <p class="text-base md:text-lg text-[#7F7F7F] mb-8 leading-[1.6]">
                {t("landing.description")}
              </p>
              <div class="flex gap-4 flex-col sm:flex-row">
                <button
                  id="hero-primary-btn"
                  class="px-8 py-3 h-[52px] text-base rounded-full bg-[#1a1a1a] text-white hover:bg-[#333333] transition-all hover:scale-105 font-medium"
                >
                  {t("landing.gettingStarted")}
                </button>
                <button
                  id="hero-secondary-btn"
                  class="px-8 py-3 h-[52px] text-base rounded-full border border-[#1a1a1a]/20 text-[#1a1a1a] hover:bg-[#1a1a1a]/5 transition-colors font-medium"
                >
                  {t("landing.learnMore")}
                </button>
              </div>
            </div>
            
            <div class="w-full max-w-md lg:max-w-lg">
              <svg viewBox="0 0 850 284" class="w-full h-auto">
                <g>
                  <path d="M461.539,74.545l104.592,-0l0,29.849l-104.801,0l-0,178.939l74.686,0l0,-104.394l30.116,0l0,104.394l74.686,0l0,-195.179l-0.01,0c-0.704,-48.739 -40.452,-88.044 -89.419,-88.153l0,-0.001l-0.201,0l-0.009,-0l0,0l-89.639,0l0,74.545Z" style="fill:#1a1a1a;"/>
                  <path d="M670.513,283.333l89.429,0c49.506,0 89.639,-40.057 89.639,-89.47l-0,-0.002l0,-89.465l-89.025,0l-0.034,-0l-0.37,-0.001l0,-29.85l89.848,0l0,-74.545l-89.848,0c-49.506,0 -89.639,40.057 -89.639,89.47c-0,0 -0,89.47 -0,89.47l89.429,0l0,29.849l-89.429,0l0,74.545Z" style="fill:#1a1a1a;"/>
                  <rect x="0" y="208.789" width="430.95" height="74.545" style="fill:#4646b9;"/>
                  <rect x="-0" y="104.394" width="431.423" height="74.545" style="fill:#16a34a;"/>
                  <rect x="0.474" y="-0" width="430.95" height="74.545" style="fill:#B94747;"/>
                </g>
              </svg>
            </div>
          </div>
          
          <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[#7F7F7F] animate-bounce cursor-pointer" id="scroll-indicator">
            <span class="text-sm">{t("landing.scrollDown")}</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </div>
        </div>
      </section>

      <section id="features" class="py-20 md:py-32 bg-white">
        <div class="container mx-auto px-5 md:px-20 max-w-7xl">
          <h2 class="text-[32px] md:text-[40px] font-semibold text-center mb-16 text-[#1a1a1a]" style="font-family: Georgia, 'Times New Roman', serif;">
            {t("landing.featuresTitle")}
          </h2>
          
          <div class="grid md:grid-cols-3 gap-6 md:gap-8">
            <div class="feature-card group p-6 md:p-8 rounded-2xl bg-[#F4F4EF] border border-[#E0DFD6] hover:border-[#B94747]/30 hover:shadow-lg transition-all duration-300">
              <div class="w-12 h-12 mb-4 rounded-xl bg-[#B94747]/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-[#B94747]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold mb-2 text-[#1a1a1a]">{t("landing.plugAndPlayTitle")}</h3>
              <p class="text-[#656565] text-sm leading-relaxed">{t("landing.plugAndPlayDesc")}</p>
            </div>

            <div class="feature-card group p-6 md:p-8 rounded-2xl bg-[#F4F4EF] border border-[#E0DFD6] hover:border-[#16a34a]/30 hover:shadow-lg transition-all duration-300">
              <div class="w-12 h-12 mb-4 rounded-xl bg-[#16a34a]/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-[#16a34a]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold mb-2 text-[#1a1a1a]">{t("landing.deferredTitle")}</h3>
              <p class="text-[#656565] text-sm leading-relaxed">{t("landing.deferredDesc")}</p>
            </div>

            <div class="feature-card group p-6 md:p-8 rounded-2xl bg-[#F4F4EF] border border-[#E0DFD6] hover:border-[#4646B9]/30 hover:shadow-lg transition-all duration-300">
              <div class="w-12 h-12 mb-4 rounded-xl bg-[#4646B9]/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-[#4646B9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-semibold mb-2 text-[#1a1a1a]">{t("landing.forwardTitle")}</h3>
              <p class="text-[#656565] text-sm leading-relaxed">{t("landing.forwardDesc")}</p>
            </div>
          </div>
        </div>
      </section>

      <section class="py-20 md:py-32 bg-[#F0EFE7]">
        <div class="container mx-auto px-5 md:px-20 max-w-7xl">
          <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
            <div class="lg:w-1/2">
              <div class="w-full h-48 md:h-64 lg:h-72 rounded-2xl overflow-hidden shadow-lg">
                <img src="https://res.errore.ink/ers/ers_deferred.png" alt="Deferred Rendering" class="w-full h-full object-cover" />
              </div>
            </div>
            <div class="lg:w-1/2">
              <h2 class="text-[28px] md:text-[36px] font-semibold mb-4 text-[#1a1a1a]" style="font-family: Georgia, 'Times New Roman', serif;">
                {t("landing.deferredTitle")}
              </h2>
              <p class="text-[#656565] text-base leading-relaxed mb-6">
                {t("landing.deferredDesc")}
              </p>
              <ul class="space-y-3">
                <li class="flex items-center gap-3 text-[#1a1a1a]">
                  <span class="w-2 h-2 rounded-full bg-[#16a34a]"></span>
                  <span>{t("landing.deferredFeature1")}</span>
                </li>
                <li class="flex items-center gap-3 text-[#1a1a1a]">
                  <span class="w-2 h-2 rounded-full bg-[#16a34a]"></span>
                  <span>{t("landing.deferredFeature2")}</span>
                </li>
                <li class="flex items-center gap-3 text-[#656565]">
                  <span class="w-2 h-2 rounded-full bg-[#9CA3AF]"></span>
                  <span>{t("landing.deferredFeature3")} <span class="text-xs bg-[#D4D4CF] text-[#4B4B4B] px-2 py-0.5 rounded-full ml-1">{t("landing.comingSoon")}</span></span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section class="py-20 md:py-32 bg-white">
        <div class="container mx-auto px-5 md:px-20 max-w-7xl">
          <div class="flex flex-col lg:flex-row-reverse items-center gap-10 lg:gap-16">
            <div class="lg:w-1/2">
              <div class="w-full h-48 md:h-64 lg:h-72 rounded-2xl overflow-hidden shadow-lg">
                <img src="https://res.errore.ink/ers/ers_forward.png" alt="Forward Rendering" class="w-full h-full object-cover" />
              </div>
            </div>
            <div class="lg:w-1/2">
              <h2 class="text-[28px] md:text-[36px] font-semibold mb-4 text-[#1a1a1a]" style="font-family: Georgia, 'Times New Roman', serif;">
                {t("landing.forwardTitle")}
              </h2>
              <p class="text-[#656565] text-base leading-relaxed mb-6">
                {t("landing.forwardDesc")}
              </p>
              <ul class="space-y-3">
                <li class="flex items-center gap-3 text-[#1a1a1a]">
                  <span class="w-2 h-2 rounded-full bg-[#4646B9]"></span>
                  <span>{t("landing.forwardFeature1")}</span>
                </li>
                <li class="flex items-center gap-3 text-[#1a1a1a]">
                  <span class="w-2 h-2 rounded-full bg-[#4646B9]"></span>
                  <span>{t("landing.forwardFeature2")}</span>
                </li>
                <li class="flex items-center gap-3 text-[#1a1a1a]">
                  <span class="w-2 h-2 rounded-full bg-[#4646B9]"></span>
                  <span>{t("landing.forwardFeature3")}</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section id="faq" class="py-20 md:py-32 bg-[#F4F4EF]">
        <div class="container mx-auto px-5 md:px-20 max-w-7xl">
          <div class="flex flex-col md:flex-row gap-10 md:gap-20">
            <div class="md:w-1/3">
              <h2 class="text-[32px] md:text-[40px] font-semibold text-[#1a1a1a]" style="font-family: Georgia, 'Times New Roman', serif;">
                {t("landing.faqTitle")}
              </h2>
            </div>
            
            <div class="md:w-2/3">
              <div class="flex flex-col gap-4">
                <div class="faq-item rounded-2xl bg-[#EBEBE6] border border-[#DCDCD7] overflow-hidden">
                  <button class="faq-toggle w-full text-left p-5 md:p-6 flex justify-between items-center cursor-pointer">
                    <span class="text-base md:text-lg font-medium text-[#1a1a1a]">{t("landing.faqQ1")}</span>
                    <svg class="faq-icon w-5 h-5 text-[#7F7F7F] transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </button>
                  <div class="faq-content overflow-hidden max-h-0 transition-all duration-300">
                    <p class="px-5 md:px-6 pb-5 md:pb-6 text-[#656565]">{t("landing.faqA1")}</p>
                  </div>
                </div>

                <div class="faq-item rounded-2xl bg-[#EBEBE6] border border-[#DCDCD7] overflow-hidden">
                  <button class="faq-toggle w-full text-left p-5 md:p-6 flex justify-between items-center cursor-pointer">
                    <span class="text-base md:text-lg font-medium text-[#1a1a1a]">{t("landing.faqQ2")}</span>
                    <svg class="faq-icon w-5 h-5 text-[#7F7F7F] transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
